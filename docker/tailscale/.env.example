# Tailscale Configuration
# Get auth key from: https://login.tailscale.com/admin/settings/keys

TAILSCALE_AUTHKEY=tskey-auth-xxxxxxxxxxxxxxxx
TAILSCALE_HOSTNAME=pi-commander
# DNS-only remote setup for AdGuard + LAN access via subnet routing
# Replace subnet with your LAN (example 192.168.1.0/24)
TAILSCALE_EXTRA_ARGS=--accept-dns=true --advertise-routes=192.168.1.0/24
